<!DOCTYPE html>
<html lang="gu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>જનરલ નોલેજ ૧૦૦ પ્રશ્નો ટેસ્ટ</title>
    <style>
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #f0f2f5;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .quiz-container {
            background-color: #ffffff;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 650px;
            padding: 30px;
            box-sizing: border-box;
        }
        h2 {
            color: #e67e22;
            text-align: center;
            margin-bottom: 25px;
        }
        .question {
            font-size: 20px;
            font-weight: 600;
            color: #1a1a1a;
            margin-bottom: 20px;
            line-height: 1.5;
        }
        .options-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .option-btn {
            background-color: #f8f9fa;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            padding: 15px;
            font-size: 16px;
            text-align: left;
            cursor: pointer;
            transition: all 0.2s ease;
            width: 100%;
        }
        .option-btn:hover {
            background-color: #e8f0fe;
            border-color: #e67e22;
        }
        .correct {
            background-color: #d4edda !important;
            border-color: #28a745 !important;
            color: #155724 !important;
        }
        .wrong {
            background-color: #f8d7da !important;
            border-color: #dc3545 !important;
            color: #721c24 !important;
        }
        .footer {
            margin-top: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid #eee;
            padding-top: 15px;
        }
        .next-btn {
            background-color: #e67e22;
            color: white;
            border: none;
            padding: 10px 25px;
            font-size: 16px;
            border-radius: 6px;
            cursor: pointer;
            display: none;
        }
        .next-btn:hover {
            background-color: #d35400;
        }
        .result-card {
            text-align: center;
        }
        .restart-btn {
            background-color: #28a745;
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 16px;
            border-radius: 6px;
            cursor: pointer;
            margin-top: 20px;
        }
    </style>
</head>
<body>

<div class="quiz-container">
    <div id="quiz-box">
        <h2>સામાન્ય જ્ઞાન મહા ટેસ્ટ (૧૦૦ પ્રશ્નો)</h2>
        <div class="question" id="question">પ્રશ્ન લોડ થઈ રહ્યો છે...</div>
        <div class="options-container" id="options"></div>
        <div class="footer">
            <span id="progress">પ્રશ્ન 0 / 0</span>
            <button class="next-btn" id="next-btn">આગળનો પ્રશ્ન</button>
        </div>
    </div>
</div>

<script>
    const quizData = [
        { question: "ભારતનું બંધારણ ક્યારે અમલમાં આવ્યું?", a: "૧૫ ઓગસ્ટ ૧૯૪૭", b: "૨૬ જાન્યુઆરી ૧૯૫૦", c: "૨૬ નવેમ્બર ૧૯૪૯", d: "૩૦ જાન્યુઆરી ૧૯૪૮", correct: "b" },
        { question: "ક્ષેત્રફળની દ્રષ્ટિએ ભારતનું સૌથી મોટું રાજ્ય કયું છે?", a: "મધ્યપ્રદેશ", b: "ઉત્તરપ્રદેશ", c: "રાજસ્થાન", d: "મહારાષ્ટ્ર", correct: "c" },
        { question: "ગુજરાતની સ્થાપના ક્યારે થઈ હતી?", a: "૧ મે ૧૯૬૦", b: "૧ મે ૧૯૫૬", c: "૧૫ ઓગસ્ટ ૧૯૪૭", d: "૨૬ જાન્યુઆરી ૧૯૫૦", correct: "a" },
        { question: "ભારતના બંધારણના ઘડવૈયા (પિતા) કોણ ગણાય છે?", a: "મહાત્મા ગાંધી", b: "ડો. બી. આર. આંબેડકર", c: "જવાહરલાલ નહેરૂ", d: "સરદાર પટેલ", correct: "b" },
        { question: "ગીર રાષ્ટ્રીય ઉદ્યાન કયા પ્રાણી માટે પ્રખ્યાત છે?", a: "વાઘ", b: "એશિયાઈ સિંહ", c: "દીપડો", d: "એકશિંગી ગેંડો", correct: "b" },
        { question: "વિશ્વનો સૌથી મોટો મહાસાગર કયો છે?", a: "એટલાન્ટિક મહાસાગર", b: "હિંદ મહાસાગર", c: "પેસિફિક મહાસાગર", d: "આર્કટિક મહાસાગર", correct: "c" },
        { question: "ભારતની સંસદમાં કયા બે ગૃહો હોય છે?", a: "વિધાનસભા અને લોકસભા", b: "લોકસભા અને રાજ્યસભા", c: "રાજ્યસભા અને વિધાનપરિષદ", d: "સુપ્રીમ કોર્ટ અને લોકસભા", correct: "b" },
        { question: "સૂર્યમંડળનો સૌથી મોટો ગ્રહ કયો છે?", a: "પૃથ્વી", b: "શનિ", c: "મંગળ", d: "ગુરુ", correct: "d" },
        { question: "ગુજરાતની સૌથી લાંબી નદી કઈ છે?", a: "તાપી", b: "મહી", c: "નર્મદા", d: "સાબરમતી", correct: "c" },
        { question: "માનવ શરીરમાં કુલ કેટલા હાડકાં હોય છે?", a: "૨૦૬", b: "૩૦૬", c: "૧૦૬", d: "૨૫૦", correct: "a" },
        { question: "લોહી શુદ્ધ કરવાનું કામ શરીરનું કયું અંગ કરે છે?", a: "હૃદય", b: "ફેફસાં", c: "કિડની (મૂત્રપિંડ)", d: "જઠર", correct: "c" },
        { question: "પાણીનું રાસાયણિક સૂત્ર શું છે?", a: "CO2", b: "H2O", c: "O2", d: "NaCl", correct: "b" },
        { question: "સ્વરાજ મારો જન્મસિદ્ધ અધિકાર છે, આ સૂત્ર કોણે આપ્યું હતું?", a: "સુભાષચંદ્ર બોઝ", b: "બાળ ગંગાધર તિળક", c: "ભગતસિંહ", d: "લાલા લાજપત રાય", correct: "b" },
        { question: "ગાંધીજીએ કયા વર્ષે દાંડી કૂચ કરી હતી?", a: "૧૯૨૦", b: "૧૯૩૦", c: "૧૯૪૨", d: "૧૯૧૫", correct: "b" },
        { question: "વિટામિન સી ની ઉણપથી કયો રોગ થાય છે?", a: "રતાંધળાપણું", b: "બેરીબેરી", c: "સ્કર્વી", d: "સુક્તાન", correct: "c" },
        { question: "ભારતના પ્રથમ રાષ્ટ્રપતિ કોણ હતા?", a: "ડો. રાજેન્દ્ર પ્રસાદ", b: "જવાહરલાલ નહેરૂ", c: "ડો. રાધાકૃષ્ણન", d: "સરદાર પટેલ", correct: "a" },
        { question: "કયું વિટામિન સૂર્યના કિરણોમાંથી મળે છે?", a: "વિટામિન A", b: "વિટામિન B", c: "વિટામિન C", d: "વિટામિન D", correct: "d" },
        { question: "ગુજરાતનું રાજ્ય પક્ષી કયું છે?", a: "મોર", b: "પોપટ", c: "ફ્લેમિંગો (સુરખાબ)", d: "કબૂતર", correct: "c" },
        { question: "દુનિયાનું સૌથી મોટું રણ કયું છે?", a: "થારનું રણ", b: "સહારાનું રણ", c: "ગોબીનું રણ", d: "કચ્છનું રણ", correct: "b" },
        { question: "લોકસભાના સભ્ય બનવા માટે લઘુત્તમ ઉંમર કેટલી હોવી જોઈએ?", a: "૧૮ વર્ષ", b: "૨૧ વર્ષ", c: "૨૫ વર્ષ", d: "૩૦ વર્ષ", correct: "c" },
        { question: "રણમાં મુસાફરી કરવા માટે કયું પ્રાણી શ્રેષ્ઠ ગણાય છે?", a: "ઘોડો", b: "ઊંટ", c: "હાથી", d: "બળદ", correct: "b" },
        { question: "સિદ્ધરાજ જયસિંહ કયા વંશના રાજા હતા?", a: "ચાવડા વંશ", b: "સોલંકી વંશ", c: "વાઘેલા વંશ", d: "ગુપ્ત વંશ", correct: "b" },
        { question: "કટોકટીની જાહેરાત કરવાની સત્તા કોની પાસે હોય છે?", a: "વડાપ્રધાન", b: "રાષ્ટ્રપતિ", c: "સુપ્રીમ કોર્ટના મુખ્ય ન્યાયાધીશ", d: "ગૃહમંત્રી", correct: "b" },
        { question: "પૃથ્વી પોતાની ધરી પર એક ચક્કર પૂરું કરતાં કેટલો સમય લે છે?", a: "૩૬૫ દિવસ", b: "૧૨ કલાક", c: "૨૪ કલાક", d: "૩૦ દિવસ", correct: "c" },
        { question: "જલ્લીકટ્ટુ રમત કયા રાજ્ય સાથે જોડાયેલી છે?", a: "કેરળ", b: "તામિલનાડુ", c: "કર્ણાટક", d: "આંધ્રપ્રદેશ", correct: "b" },
        { question: "ભારતનો રાષ્ટ્રીય રમત કઈ ગણાય છે (સત્તાવાર પ્રથા મુજબ)?", a: "ક્રિકેટ", b: "હોકી", c: "કબડ્ડી", d: "ફૂટબોલ", correct: "b" },
        { question: "રણછોડલાલ છોટાલાલે ગુજરાતમાં સૌપ્રથમ સુતરાઉ કાપડની મિલ ક્યાં શરૂ કરી હતી?", a: "સુરત", b: "ભરૂચ", c: "અમદાવાદ", d: "વડોદરા", correct: "c" },
        { question: "ભારતની મધ્યમાંથી કયું વૃત્ત પસાર થાય છે?", a: "મકરવૃત્ત", b: "વિષુવવૃત્ત", c: "કર્કવૃત્ત", d: "ગ્રીનિચ રેખા", correct: "c" },
        { question: "અસહકારનું આંદોલન ગાંધીજીએ કઈ ઘટનાને કારણે પાછું ખેંચ્યું હતું?", a: "જલિયાવાલા બાગ હત્યાકાંડ", b: "ચોરીચોરા કાંડ", c: "કાકોરી ટ્રેન લૂંટ", d: "બારડોલી સત્યાગ્રહ", correct: "b" },
        { question: "ગુરુત્વાકર્ષણ બળની શોધ કોણે કરી હતી?", a: "આલ્બર્ટ આઈન્સ્ટાઈન", b: "આઇઝેક ન્યૂટન", c: "ગેલિલિયો", d: "થોમસ એડિસન", correct: "b" },
        { question: "આર્યસમાજની સ્થાપના કોણે કરી હતી?", a: "સ્વામી વિવેકાનંદ", b: "રાજા રામમોહન રાય", c: "સ્વામી દયાનંદ સરસ્વતી", d: "રામકૃષ્ણ પરમહંસ", correct: "c" },
        { question: "લાફિંગ ગેસ (હસાવનારો ગેસ) તરીકે કયો ગેસ ઓળખાય છે?", a: "નાઈટ્રસ ઓક્સાઈડ", b: "કાર્બન મોનોક્સાઈડ", c: "સલ્ફર ડાયોક્સાઈડ", d: "મિથેન", correct: "a" },
        { question: "આઝાદ હિંદ ફોજની સ્થાપના કોણે કરી હતી (પુનઃગઠન નેતૃત્વ)?", a: "ભગતસિંહ", b: "ચંદ્રશેખર આઝાદ", c: "સુભાષચંદ્ર બોઝ", d: "રાસબિહારી બોઝ", correct: "c" },
        { question: "નીચેનામાંથી કયો ગ્રહ લાલ ગ્રહ તરીકે ઓળખાય છે?", a: "બુધ", b: "શુક્ર", c: "મંગળ", d: "ગુરુ", correct: "c" },
        { question: "સ્ટેચ્યુ ઓફ યુનિટી કઈ નદીના ટાપુ પર બનેલું છે?", a: "તાપી", b: "નર્મદા", c: "સાબરમતી", d: "મહી", correct: "b" },
        { question: "ઇન્સ્યુલિનની ઉણપથી કયો રોગ થાય છે?", a: "એનિમિયા", b: "ડાયાબિટીસ (મધુપ્રમેહ)", c: "ગોઇટર", d: "ટાઇફોઇડ", correct: "b" },
        { question: "સૂર્યપ્રકાશને પૃથ્વી પર પહોંચતા આશરે કેટલો સમય લાગે છે?", a: "૨ મિનિટ", b: "૫ મિનિટ", c: "૮ મિનિટ", d: "૧૫ મિનિટ", correct: "c" },
        { question: "હવામહેલ કયા શહેરમાં આવેલો છે?", a: "ઉદયપુર", b: "જયપુર", c: "જોધપુર", d: "જેસલમેર", correct: "b" },
        { question: "ગાયત્રી મંત્રની રચના કયા વેદમાં કરવામાં આવી છે?", a: "ઋગ્વેદ", b: "સામવેદ", c: "યજુર્વેદ", d: "અથર્વવેદ", correct: "a" },
        { question: "ઓઝોન સ્તર કયા હાનિકારક કિરણોથી પૃથ્વીનું રક્ષણ કરે છે?", a: "ઇન્ફ્રારેડ કિરણો", b: "અલ્ટ્રાવાયોલેટ (પારજાંબલી) કિરણો", c: "એક્સ રેઝ", d: "ગામા કિરણો", correct: "b" },
        { question: "વિશ્વ પર્યાવરણ દિવસ ક્યારે ઉજવવામાં આવે છે?", a: "૫ જૂન", b: "૧૧ જુલાઈ", c: "૨૨ એપ્રિલ", d: "૧ ડિસેમ્બર", correct: "a" },
